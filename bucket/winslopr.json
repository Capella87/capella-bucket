{
    "version": "26.04.04",
    "description": "De-slop Windows.",
    "homepage": "https://github.com/builtbybel/Winslopr",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/builtbybel/Winslopr/releases/download/26.04.04/Winslopr-26.04.04-win-x64.zip",
            "hash": "767717646b43787ac19f698fbc1086d91f7c69fae7a470cd4ef78f31d4a4166f"
        }
    },
    "pre_install": [
        "$configFileExists = Test-Path $persist_dir\\Winslopr.txt",
        "if (-not $configFileExists) { Add-Content $dir\\Winslopr.txt '{\"AutoUpdate\": \"0\"}' -Encoding utf8NoBOM }"
    ],
    "shortcuts": [
        [
            "Winslopr.exe",
            "Winslopr",
            "",
            "Winslopr.exe"
        ]
    ],
    "persist": "Winslopr.txt",
    "checkver": {
        "github": "https://github.com/builtbybel/Winslopr",
        "regex": "tag/([\\w\\.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/builtbybel/Winslopr/releases/download/$version/Winslopr-$version-win-x64.zip"
            }
        }
    }
}
